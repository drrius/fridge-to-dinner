# Server-side OpenAI provider configuration for the Next.js API service.
# Fill these in locally in .env.local. Do not expose them to the iOS client.
OPENAI_API_KEY=
OPENAI_MODEL=

# Planned Phase 5 rate-limit controls. Values are placeholders until implemented.
RATE_LIMIT_DAILY_SCANS=5
RATE_LIMIT_WINDOW_SECONDS=86400
